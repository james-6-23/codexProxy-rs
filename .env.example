# ============================================================
# CodexProxy-RS 配置
# 复制为 .env 后修改
# ============================================================

# 服务端口
CODEX_PORT=6592

# 管理后台密码（留空 = 不启用认证）
# ADMIN_SECRET=your-password

# 全局代理（可选）
# PROXY_URL=http://host.docker.internal:7890

# 时区
TZ=Asia/Shanghai
